  "range-cache-file:///c%3A/Users/RUHAN/.ai_completion/frontend/package.json": "[{\"originRange\":{\"start\":{\"line\":0,\"character\":0},\"end\":{\"line\":26,\"character\":0}},\"modifyRange\":{\"start\":{\"line\":0,\"character\":0},\"end\":{\"line\":26,\"character\":0}},\"action\":\"None\",\"isLine\":false,\"originText\":\"{\\\\n  \\\\\\\"name\\\\\\\": \\\\\\\"medbuddy-frontend\\\\\\\",\\\\n  \\\\\\\"private\\\\\\\": true,\\\\n  \\\\\\\"version\\\\\\\": \\\\\\\"1.0.0\\\\\\\",\\\\n  \\\\\\\"type\\\\\\\": \\\\\\\"module\\\\\\\",\\\\n  \\\\\\\"scripts\\\\\\\": {\\\\n    \\\\\\\"dev\\\\\\\": \\\\\\\"vite\\\\\\\",\\\\n    \\\\\\\"build\\\\\\\": \\\\\\\"vite build\\\\\\\",\\\\n    \\\\\\\"preview\\\\\\\": \\\\\\\"vite preview\\\\\\\"\\\\n  },\\\\n  \\\\\\\"dependencies\\\\\\\": {\\\\n    \\\\\\\"framer-motion\\\\\\\": \\\\\\\"^11.0.0\\\\\\\",\\\\n    \\\\\\\"lucide-react\\\\\\\": \\\\\\\"^0.344.0\\\\\\\",\\\\n    \\\\\\\"react\\\\\\\": \\\\\\\"^18.2.0\\\\\\\",\\\\n    \\\\\\\"react-dom\\\\\\\": \\\\\\\"^18.2.0\\\\\\\"\\\\n  },\\\\n  \\\\\\\"devDependencies\\\\\\\": {\\\\n    \\\\\\\"@types/react\\\\\\\": \\\\\\\"^18.2.66\\\\\\\",\\\\n    \\\\\\\"@types/react-dom\\\\\\\": \\\\\\\"^18.2.22\\\\\\\",\\\\n    \\\\\\\"@vitejs/plugin-react\\\\\\\": \\\\\\\"^4.2.1\\\\\\\",\\\\n    \\\\\\\"autoprefixer\\\\\\\": \\\\\\\"^10.4.18\\\\\\\",\\\\n    \\\\\\\"postcss\\\\\\\": \\\\\\\"^8.4.35\\\\\\\",\\\\n    \\\\\\\"tailwindcss\\\\\\\": \\\\\\\"^3.4.1\\\\\\\",\\\\n    \\\\\\\"vite\\\\\\\": \\\\\\\"^5.1.6\\\\\\\"\\\\n  }\\\\n}\\\\n\",\"originAcceptText\":\"{\\n  \\\"name\\\": \\\"medbuddy-frontend\\\",\\n  \\\"private\\\": true,\\n  \\\"version\\\": \\\"1.0.0\\\",\\n  \\\"type\\\": \\\"module\\\",\\n  \\\"scripts\\\": {\\n    \\\"dev\\\": \\\"vite\\\",\\n    \\\"build\\\": \\\"vite build\\\",\\n    \\\"preview\\\": \\\"vite preview\\\"\\n  },\\n  \\\"dependencies\\\": {\\n    \\\"framer-motion\\\": \\\"^11.0.0\\\",\\n    \\\"lucide-react\\\": \\\"^0.344.0\\\",\\n    \\\"react\\\": \\\"^18.2.0\\\",\\n    \\\"react-dom\\\": \\\"^18.2.0\\\"\\n  },\\n  \\\"devDependencies\\\": {\\n    \\\"@types/react\\\": \\\"^18.2.66\\\",\\n    \\\"@types/react-dom\\\": \\\"^18.2.22\\\",\\n    \\\"@vitejs/plugin-react\\\": \\\"^4.2.1\\\",\\n    \\\"autoprefixer\\\": \\\"^10.4.18\\\",\\n    \\\"postcss\\\": \\\"^8.4.35\\\",\\n    \\\"tailwindcss\\\": \\\"^3.4.1\\\",\\n    \\\"vite\\\": \\\"^5.1.6\\\"\\n  }\\n}\\n\",\"originTextLength\":573,\"aiScene\":\"Completion\",\"behaviorType\":\"accept\",\"updateTime\":1774257120890}]",
  "range-cache-file:///c%3A/Users/RUHAN/.ai_completion/frontend/src/App.jsx": "[{\"originRange\":{\"start\":{\"line\":12,\"character\":0},\"end\":{\"line\":53,\"character\":0}},\"modifyRange\":{\"start\":{\"line\":12,\"character\":0},\"end\":{\"line\":53,\"character\":0}},\"action\":\"None\",\"isLine\":false,\"originText\":\"const globalStyles = `\\\\n@import url(\\\\'https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Barlow:wght@300;400;500;600&display=swap\\\\');\\\\n\\\\n* { box-sizing: border-box; }\\\\nbody { background: #02040A; font-family: \\\\'Barlow\\\\', sans-serif; margin: 0; color: white; }\\\\n::selection { background: rgba(16,185,129,0.3); color: white; }\\\\n.font-heading { font-family: \\\\'Instrument Serif\\\\', serif; }\\\\n.font-body { font-family: \\\\'Barlow\\\\', sans-serif; }\\\\n\\\\n.liquid-glass {\\\\n  background: rgba(255,255,255,0.015);\\\\n  background-blend-mode: luminosity;\\\\n  backdrop-filter: blur(8px);\\\\n  -webkit-backdrop-filter: blur(8px);\\\\n  border: none;\\\\n  box-shadow: inset 0 1px 1px rgba(255,255,255,0.1), 0 4px 24px rgba(0,0,0,0.2);\\\\n  position: relative;\\\\n  overflow: hidden;\\\\n  transition: all 0.4s cubic-bezier(0.16,1,0.3,1);\\\\n}\\\\n.liquid-glass::before {\\\\n  content: \\\\'\\\\'; position: absolute; inset: 0; border-radius: inherit; padding: 1px;\\\\n  background: linear-gradient(180deg, rgba(255,255,255,0.3) 0%, rgba(255,255,255,0.05) 20%, rgba(255,255,255,0) 40%, rgba(255,255,255,0) 60%, rgba(255,255,255,0.05) 80%, rgba(255,255,255,0.2) 100%);\\\\n  -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);\\\\n  -webkit-mask-composite: xor; mask-composite: exclude; pointer-events: none;\\\\n}\\\\n.liquid-glass-strong {\\\\n  background: rgba(255,255,255,0.02);\\\\n  background-blend-mode: luminosity;\\\\n  backdrop-filter: blur(50px);\\\\n  -webkit-backdrop-filter: blur(50px);\\\\n  border: none;\\\\n  box-shadow: 0 8px 32px rgba(0,0,0,0.3), inset 0 1px 1px rgba(255,255,255,0.2);\\\\n  position: relative; overflow: hidden;\\\\n  transition: all 0.4s cubic-bezier(0.16,1,0.3,1);\\\\n}\\\\n.liquid-glass-strong::before {\\\\n  content: \\\\'\\\\'; position: absolute; inset: 0; border-radius: inherit; padding: 1.2px;\\\\n  background: linear-gradient(180deg, rgba(255,255,255,0.6) 0%, rgba(255,255,255,0.15) 20%, rgba(255,255,255,0) 40%, rgba(255,255,255,0) 60%, rgba(255,255,255,0.15) 80%, rgba(255,255,255,0.4) 100%);\\\\n  -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);\\\\n  -webkit-mask-composite: xor; mask-composite: exclude; pointer-events: none;\\\\n}\\\\n`;\\\\n\",\"originAcceptText\":\"const globalStyles = `\\n@import url('https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Barlow:wght@300;400;500;600&display=swap');\\n\\n* { box-sizing: border-box; }\\nbody { background: #02040A; font-family: 'Barlow', sans-serif; margin: 0; color: white; }\\n::selection { background: rgba(16,185,129,0.3); color: white; }\\n.font-heading { font-family: 'Instrument Serif', serif; }\\n.font-body { font-family: 'Barlow', sans-serif; }\\n\\n.liquid-glass {\\n  background: rgba(255,255,255,0.015);\\n  background-blend-mode: luminosity;\\n  backdrop-filter: blur(8px);\\n  -webkit-backdrop-filter: blur(8px);\\n  border: none;\\n  box-shadow: inset 0 1px 1px rgba(255,255,255,0.1), 0 4px 24px rgba(0,0,0,0.2);\\n  position: relative;\\n  overflow: hidden;\\n  transition: all 0.4s cubic-bezier(0.16,1,0.3,1);\\n}\\n.liquid-glass::before {\\n  content: ''; position: absolute; inset: 0; border-radius: inherit; padding: 1px;\\n  background: linear-gradient(180deg, rgba(255,255,255,0.3) 0%, rgba(255,255,255,0.05) 20%, rgba(255,255,255,0) 40%, rgba(255,255,255,0) 60%, rgba(255,255,255,0.05) 80%, rgba(255,255,255,0.2) 100%);\\n  -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);\\n  -webkit-mask-composite: xor; mask-composite: exclude; pointer-events: none;\\n}\\n.liquid-glass-strong {\\n  background: rgba(255,255,255,0.02);\\n  background-blend-mode: luminosity;\\n  backdrop-filter: blur(50px);\\n  -webkit-backdrop-filter: blur(50px);\\n  border: none;\\n  box-shadow: 0 8px 32px rgba(0,0,0,0.3), inset 0 1px 1px rgba(255,255,255,0.2);\\n  position: relative; overflow: hidden;\\n  transition: all 0.4s cubic-bezier(0.16,1,0.3,1);\\n}\\n.liquid-glass-strong::before {\\n  content: ''; position: absolute; inset: 0; border-radius: inherit; padding: 1.2px;\\n  background: linear-gradient(180deg, rgba(255,255,255,0.6) 0%, rgba(255,255,255,0.15) 20%, rgba(255,255,255,0) 40%, rgba(255,255,255,0) 60%, rgba(255,255,255,0.15) 80%, rgba(255,255,255,0.4) 100%);\\n  -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);\\n  -webkit-mask-composite: xor; mask-composite: exclude; pointer-events: none;\\n}\\n`;\\n\",\"originTextLength\":2106,\"aiScene\":\"Completion\",\"behaviorType\":\"accept\",\"updateTime\":1774257120893}]",
  "range-cache-file:///c%3A/Users/RUHAN/.ai_completion/README.md": "[{\"originRange\":{\"start\":{\"line\":0,\"character\":0},\"end\":{\"line\":44,\"character\":0}},\"modifyRange\":{\"start\":{\"line\":0,\"character\":0},\"end\":{\"line\":44,\"character\":0}},\"action\":\"None\",\"isLine\":false,\"originText\":\"# MedBuddy — The AI That Sits Between a Patient and Confusion\\\\n\\\\n**IAR Udaan Hackathon 2026 — Day 1**\\\\n\\\\nMedBuddy is an AI-powered medical document simplifier that helps patients understand their prescriptions, discharge summaries, and lab reports in plain, human language.\\\\n\\\\n## 🚀 Features\\\\n\\\\n- **JWT Authentication**: Secure user registration and login.\\\\n- **AI Analysis**: Uses Google Gemini 1.5 Flash to parse and simplify medical documents.\\\\n- **Multi-format Support**: Upload PDF, JPG, or PNG files.\\\\n- **Structured Output**: Clear diagnosis, medication schedule (dosage, timing, duration), side effects, and follow-up checklists.\\\\n- **History Tracking**: Logged-in users can view their past analyses.\\\\n- **Modern UI**: Glassmorphic design with smooth animations.\\\\n\\\\n## 🛠️ Tech Stack\\\\n\\\\n- **Frontend**: React, Framer Motion, Tailwind CSS, Lucide Icons.\\\\n- **Backend**: FastAPI, SQLAlchemy (SQLite), JWT, Pydantic.\\\\n- **AI**: Google Generative AI (Gemini 1.5 Flash).\\\\n\\\\n## 🔧 Installation & Setup\\\\n\\\\n### Backend\\\\n\\\\n1. Navigate to the backend directory:\\\\n   ```bash\\\\n   cd backend\\\\n   ```\\\\n2. Install dependencies:\\\\n   ```bash\\\\n   pip install -r requirements.txt\\\\n   ```\\\\n3. Create a `.env` file and add your Gemini API Key:\\\\n   ```env\\\\n   GENAI_API_KEY=your_gemini_api_key\\\\n   SECRET_KEY=your_jwt_secret_key\\\\n   ```\\\\n4. Start the server:\\\\n   ```bash\\\\n   python main.py\\\\n   ```\\\\n\\\\n### Frontend\\\\n\\\\n1. Ensure you have the required React dependencies:\\\\n   ```bash\\\\n   npm install framer-motion lucide-react\\\\n   ```\\\\n2. Run your development server (e.g., Vite):\\\\n   ```bash\\\\n   npm run dev\\\\n   ```\\\\n\\\\n## 📄 License\\\\n\\\\nThis project was built for the IAR Udaan Hackathon 2026.\\\\n\",\"originAcceptText\":\"# MedBuddy — The AI That Sits Between a Patient and Confusion\\n\\n**IAR Udaan Hackathon 2026 — Day 1**\\n\\nMedBuddy is an AI-powered medical document simplifier that helps patients understand their prescriptions, discharge summaries, and lab reports in plain, human language.\\n\\n## 🚀 Features\\n\\n- **JWT Authentication**: Secure user registration and login.\\n- **AI Analysis**: Uses Google Gemini 1.5 Flash to parse and simplify medical documents.\\n- **Multi-format Support**: Upload PDF, JPG, or PNG files.\\n- **Structured Output**: Clear diagnosis, medication schedule (dosage, timing, duration), side effects, and follow-up checklists.\\n- **History Tracking**: Logged-in users can view their past analyses.\\n- **Modern UI**: Glassmorphic design with smooth animations.\\n\\n## 🛠️ Tech Stack\\n\\n- **Frontend**: React, Framer Motion, Tailwind CSS, Lucide Icons.\\n- **Backend**: FastAPI, SQLAlchemy (SQLite), JWT, Pydantic.\\n- **AI**: Google Generative AI (Gemini 1.5 Flash).\\n\\n## 🔧 Installation & Setup\\n\\n### Backend\\n\\n1. Navigate to the backend directory:\\n   ```bash\\n   cd backend\\n   ```\\n2. Install dependencies:\\n   ```bash\\n   pip install -r requirements.txt\\n   ```\\n3. Create a `.env` file and add your Gemini API Key:\\n   ```env\\n   GENAI_API_KEY=your_gemini_api_key\\n   SECRET_KEY=your_jwt_secret_key\\n   ```\\n4. Start the server:\\n   ```bash\\n   python main.py\\n   ```\\n\\n### Frontend\\n\\n1. Ensure you have the required React dependencies:\\n   ```bash\\n   npm install framer-motion lucide-react\\n   ```\\n2. Run your development server (e.g., Vite):\\n   ```bash\\n   npm run dev\\n   ```\\n\\n## 📄 License\\n\\nThis project was built for the IAR Udaan Hackathon 2026.\\n\",\"originTextLength\":1621,\"aiScene\":\"Completion\",\"behaviorType\":\"accept\",\"updateTime\":1774257120894}]",
  "range-cache-file:///c%3A/Users/RUHAN/.ai_completion/backend/.env": "[{\"originRange\":{\"start\":{\"line\":0,\"character\":0},\"end\":{\"line\":5,\"character\":13}},\"modifyRange\":{\"start\":{\"line\":0,\"character\":0},\"end\":{\"line\":5,\"character\":13}},\"action\":\"None\",\"isLine\":false,\"originText\":\"# Application Config\\\\nNODE_ENV=development\\\\nPORT=8000\\\\n\\\\n# Security\\\\nJWT_SECRET=your-super-secure-secret-key-2026\\\\n\\\\n# AI Services\",\"originAcceptText\":\"# Application Config\\nNODE_ENV=development\\nPORT=8000\\n\\n# Security\\nJWT_SECRET=your-super-secure-secret-key-2026\\n\\n# AI Services\",\"originTextLength\":123,\"aiScene\":\"Completion\",\"behaviorType\":\"accept\",\"updateTime\":1774262454798},{\"originRange\":{\"start\":{\"line\":1,\"character\":0},\"end\":{\"line\":5,\"character\":37}},\"modifyRange\":{\"start\":{\"line\":1,\"character\":0},\"end\":{\"line\":5,\"character\":37}},\"action\":\"None\",\"isLine\":false,\"originText\":\"\\\\n# Database (Optional if using SQLite)\\\\n# MONGO_URI=mongodb://127.0.0.1:27017/medbuddy\\\\n\\\\n# Webhooks\\\\nGITHUB_WEBHOOK_SECRET=optional_secret\",\"originAcceptText\":\"\\n# Database (Optional if using SQLite)\\n# MONGO_URI=mongodb://127.0.0.1:27017/medbuddy\\n\\n# Webhooks\\nGITHUB_WEBHOOK_SECRET=optional_secret\",\"originTextLength\":135,\"aiScene\":\"Completion\",\"behaviorType\":\"accept\",\"updateTime\":1774262454807}]"
